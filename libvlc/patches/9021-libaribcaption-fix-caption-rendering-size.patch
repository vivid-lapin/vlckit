From b849e29fce4aaaa454238a48344588712b82e2bf Mon Sep 17 00:00:00 2001
From: ci7lus <7887955+ci7lus@users.noreply.github.com>
Date: Sun, 5 Apr 2026 15:01:43 +0900
Subject: [PATCH] libaribcaption: fix caption rendering size

---
 modules/codec/arib/libaribcaption.c | 28 +++++++++++++++++++++-------
 1 file changed, 21 insertions(+), 7 deletions(-)

diff --git a/modules/codec/arib/libaribcaption.c b/modules/codec/arib/libaribcaption.c
index 0bf9a6228d..c5256e901a 100644
--- a/modules/codec/arib/libaribcaption.c
+++ b/modules/codec/arib/libaribcaption.c
@@ -121,14 +121,28 @@ static void SubpictureUpdate(subpicture_t *p_subpic,
     const video_format_t *p_dst_format = cfg->video_dst;
 
     bool b_src_changed = p_src_format->i_visible_width  != cfg->prev_src->i_visible_width ||
-                         p_src_format->i_visible_height != cfg->prev_src->i_visible_height;
+                         p_src_format->i_visible_height != cfg->prev_src->i_visible_height ||
+                         p_src_format->i_sar_num != cfg->prev_src->i_sar_num ||
+                         p_src_format->i_sar_den != cfg->prev_src->i_sar_den;
     bool b_dst_changed = !video_format_IsSimilar(cfg->prev_dst, p_dst_format);
 
-    unsigned i_render_area_width  = p_dst_format->i_visible_width;
-    unsigned i_render_area_height = p_src_format->i_visible_height * p_dst_format->i_visible_width /
-                                    p_src_format->i_visible_width;
-    if (b_src_changed || b_dst_changed) {
-        /* don't let library freely scale using either the min of width or height ratio */
+    unsigned i_src_visible_width = p_src_format->i_visible_width;
+    unsigned i_src_visible_height = p_src_format->i_visible_height;
+    unsigned i_sar_num = p_src_format->i_sar_num > 0 ? p_src_format->i_sar_num : 1;
+    unsigned i_sar_den = p_src_format->i_sar_den > 0 ? p_src_format->i_sar_den : 1;
+
+    /* We prefer keeping the native source width and reducing the height
+     * to match the display aspect ratio. This ensures that the render width
+     * (e.g. 1440 for HD) matches the raw video width used for snapshots/PiP.
+     * This avoids horizontal scaling during blending, which can help resolve
+     * blending failures on hardware buffers like CVPN (HEVC 10-bit).
+     *
+     * We use floor division for height to slightly round down as requested
+     * to avoid vertical overflow or alignment drift. */
+    unsigned i_render_area_width  = i_src_visible_width;
+    unsigned i_render_area_height = i_src_visible_height * i_sar_den / i_sar_num;
+
+    if (b_src_changed) {
         vlc_mutex_lock(&p_sys->aribcc_lock);
         aribcc_renderer_set_frame_size(p_sys->p_renderer, i_render_area_width,
                                                           i_render_area_height);
@@ -144,7 +158,7 @@ static void SubpictureUpdate(subpicture_t *p_subpic,
     vlc_mutex_unlock(&p_sys->aribcc_lock);
     if (status == ARIBCC_RENDER_STATUS_GOT_IMAGE_UNCHANGED) {
         /* Skip rendering since images were not changed */
-        if (!b_src_changed && !b_dst_changed) {
+        if (!b_src_changed) {
             return;
         }
     }
-- 
