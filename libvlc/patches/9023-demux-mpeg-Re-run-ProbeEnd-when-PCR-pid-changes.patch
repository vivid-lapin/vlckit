From ac2b5ff66b6d864c2de7a157488412d2fe0fb29e Mon Sep 17 00:00:00 2001
From: ci7lus <7887955+ci7lus@users.noreply.github.com>
Date: Tue, 5 May 2026 18:53:50 +0900
Subject: [PATCH 9023/9025] demux/mpeg: Re-run ProbeEnd when PCR pid changes

Some ARIB streams switch the PCR PID in a later PMT update. If the first
tail probe runs before that switch, ProbeEnd can miss the PCR at the end of
the stream and leave i_last_dts as VLC_TICK_INVALID.

Once b_last_dts_probed is set, later PMT updates do not retry ProbeEnd, so
duration probing keeps failing even after the PMT advertises the correct
PCR PID.

Retry ProbeEnd whenever a later PMT update still has no last DTS. Keep
ProbeStart as a one-time operation because the start-side probe result is
still valid for this failure mode.
---
 modules/demux/mpeg/ts_psi.c | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/modules/demux/mpeg/ts_psi.c b/modules/demux/mpeg/ts_psi.c
index 7ef3dd87211..54b58306413 100644
--- a/modules/demux/mpeg/ts_psi.c
+++ b/modules/demux/mpeg/ts_psi.c
@@ -2242,9 +2242,11 @@ static void PMTCallBack( void *data, dvbpsi_pmt_t *p_dvbpsipmt )
     UpdatePESFilters( p_demux, p_sys->seltype == PROGRAM_ALL );
 
     /* Probe Boundaries */
-    if( p_sys->b_canseek && !p_pmt->b_last_dts_probed )
+    if( p_sys->b_canseek &&
+        (!p_pmt->b_last_dts_probed || p_pmt->i_last_dts == VLC_TICK_INVALID) )
     {
-        ProbeStart( p_demux, p_pmt->i_number );
+        if( !p_pmt->b_last_dts_probed )
+            ProbeStart( p_demux, p_pmt->i_number );
         ProbeEnd( p_demux, p_pmt->i_number );
         p_pmt->b_last_dts_probed = true;
         if( p_pmt->i_last_dts != VLC_TICK_INVALID &&
