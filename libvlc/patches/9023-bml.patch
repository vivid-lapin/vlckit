+++ b/modules/codec/arib/bml_dec.c
@@ -0,0 +1,92 @@
+/*****************************************************************************
+ * bml_dec.c : ARIB BML data broadcasting decoder (passthrough to LibVLC)
+ *****************************************************************************
+ * Copyright (C) 2026 VLC authors and VideoLAN
+ *
+ * This program is free software; you can redistribute it and/or modify it
+ * under the terms of the GNU Lesser General Public License as published by
+ * the Free Software Foundation; either version 2.1 of the License, or
+ * (at your option) any later version.
+ *
+ * This program is distributed in the hope that it will be useful,
+ * but WITHOUT ANY WARRANTY; without even the implied warranty of
+ * MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE. See the
+ * GNU Lesser General Public License for more details.
+ *
+ * You should have received a copy of the GNU General Public License
+ * along with this program; if not, write to the Free Software Foundation,
+ * Inc., 51 Franklin Street, Fifth Floor, Boston MA 02110-1301, USA.
+ *****************************************************************************/
+
+#ifdef HAVE_CONFIG_H
+# include "config.h"
+#endif
+
+#include <vlc_common.h>
+#include <vlc_plugin.h>
+#include <vlc_codec.h>
+
+static int Open(vlc_object_t *);
+static void Close(vlc_object_t *);
+
+vlc_module_begin()
+    set_description(N_("ARIB BML data decoder"))
+    set_capability("decoder", 50)
+    set_callbacks(Open, Close)
+    add_shortcut("bml")
+vlc_module_end()
+
+typedef struct
+{
+    /* No private state needed for now */
+} decoder_sys_t;
+
+static int Decode(decoder_t *p_dec, block_t *p_block)
+{
+    if (p_block == NULL) /* EOF */
+        return VLCDEC_SUCCESS;
+
+    if (p_block->i_flags & (BLOCK_FLAG_DISCONTINUITY | BLOCK_FLAG_CORRUPTED))
+    {
+        block_Release(p_block);
+        return VLCDEC_SUCCESS;
+    }
+
+    /* Pass BML section data to LibVLC variable */
+    vlc_object_t *obj = VLC_OBJECT(p_dec);
+    while (obj != NULL)
+    {
+        if (var_Type(obj, "bml-data") != 0)
+        {
+            vlc_value_t val;
+            val.p_address = p_block;
+            /* We use BLOCK_FLAG_PRIVATE_MASK to signal this is a block_t pointer */
+            var_SetChecked(obj, "bml-data", VLC_VAR_ADDRESS, val);
+            var_TriggerCallback(obj, "bml-data");
+            break;
+        }
+        obj = vlc_object_parent(obj);
+    }
+
+    block_Release(p_block);
+    return VLCDEC_SUCCESS;
+}
+
+static int Open(vlc_object_t *p_this)
+{
+    decoder_t *p_dec = (decoder_t *)p_this;
+
+    if (p_dec->fmt_in->i_codec != VLC_CODEC_ARIB_BML)
+        return VLC_EGENERIC;
+
+    p_dec->pf_decode = Decode;
+    p_dec->fmt_out.i_cat = DATA_ES;
+    p_dec->fmt_out.i_codec = VLC_CODEC_ARIB_BML;
+
+    return VLC_SUCCESS;
+}
+
+static void Close(vlc_object_t *p_this)
+{
+    VLC_UNUSED(p_this);
+}
diff --git a/modules/demux/mpeg/ts_arib.c b/modules/demux/mpeg/ts_arib.c
index 3f4f221262..15bdf50371 100644
--- a/modules/demux/mpeg/ts_arib.c
+++ b/modules/demux/mpeg/ts_arib.c
@@ -28,6 +28,7 @@
 #include "ts.h"
 
 #include "ts_arib.h"
+#include "ts_streams_private.h"
 
 /*
  * ARIB TR-B21
@@ -656,3 +657,30 @@ char * ts_arib_Decode( const uint8_t *p_in, size_t i_in )
 
     return stream.ptr;
 }
+
+void BML_Section_Callback( demux_t *p_demux,
+                           const uint8_t *p_sectiondata, size_t i_sectiondata,
+                           const uint8_t *p_payloaddata, size_t i_payloaddata,
+                           void *p_pes_cb_data )
+{
+    VLC_UNUSED(p_payloaddata); VLC_UNUSED(i_payloaddata);
+    ts_stream_t *p_pes = (ts_stream_t *) p_pes_cb_data;
+
+    if( unlikely(p_pes->p_es->fmt.i_codec != VLC_CODEC_ARIB_BML) )
+        return;
+
+    ts_pmt_t *p_pmt = p_pes->p_es->p_program;
+    vlc_tick_t i_date = p_pmt->pcr.i_current;
+
+    block_t *p_content = block_Alloc( i_sectiondata );
+    if( unlikely(!p_content) )
+        return;
+
+    memcpy( p_content->p_buffer, p_sectiondata, i_sectiondata );
+    p_content->i_dts = p_content->i_pts = i_date;
+
+    if( p_pes->p_es->id )
+        es_out_Send( p_demux->out, p_pes->p_es->id, p_content );
+    else
+        block_Release( p_content );
+}
