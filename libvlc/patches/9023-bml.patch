index 95f4983688..7f8bbd1b19 100644
--- a/lib/media_player.c
+++ b/lib/media_player.c
@@ -1110,6 +1110,38 @@ void libvlc_video_set_arib_text_callbacks( libvlc_media_player_t *mp,
     var_SetAddress(p_libvlc->p_libvlc_int, "arib-text-opaque", opaque);
 }
 
+static int bml_data_var_cb(vlc_object_t *p_this, char const *psz_var,
+                             vlc_value_t oldval, vlc_value_t newval,
+                             void *p_data)
+{
+    VLC_UNUSED(p_this); VLC_UNUSED(psz_var); VLC_UNUSED(oldval);
+    libvlc_media_player_t *mp = p_data;
+    if (mp->bml_data_cb)
+    {
+        block_t *p_block = newval.p_address;
+        if (p_block)
+            mp->bml_data_cb(mp->bml_data_opaque, p_block->p_buffer, p_block->i_buffer);
+    }
+    return VLC_SUCCESS;
+}
+
+void libvlc_video_set_bml_data_callbacks( libvlc_media_player_t *mp,
+                                          libvlc_video_bml_data_cb cb,
+                                          void *opaque )
+{
+    if (var_Type(mp, "bml-data") == 0)
+        var_Create(mp, "bml-data", VLC_VAR_ADDRESS);
+
+    if (mp->bml_data_cb)
+        var_DelCallback(mp, "bml-data", bml_data_var_cb, mp);
+
+    mp->bml_data_cb = cb;
+    mp->bml_data_opaque = opaque;
+
+    if (cb)
+        var_AddCallback(mp, "bml-data", bml_data_var_cb, mp);
+}
+
 void libvlc_video_set_format_callbacks( libvlc_media_player_t *mp,
                                         libvlc_video_format_cb setup,
                                         libvlc_video_cleanup_cb cleanup )
