From d3cf5a20f6f7d2c2c260343f30b1984e69bc0294 Mon Sep 17 00:00:00 2001
From: ci7lus <7887955+ci7lus@users.noreply.github.com>
Date: Tue, 5 May 2026 18:55:12 +0900
Subject: [PATCH 9024/9025] demux/mpeg: Fix TimeStampWrapAround when PCR pid
 changes

After retrying ProbeEnd for a new PCR PID, the tail DTS can come from the
new PCR timeline while the wraparound anchor still uses
p_pmt->pcr.i_first_dts from the earlier start-side probe.

That makes a valid tail DTS look older than the start timestamp and can
send DEMUX_GET_LENGTH down the "Can't get stream duration. Edited ?" path
even though the tail probe succeeded.

Use the effective probe start as the wraparound reference: prefer
p_pmt->pcr.i_first when it is available, otherwise fall back to
p_pmt->pcr.i_first_dts.
---
 modules/demux/mpeg/ts_psi.c | 5 +++--
 1 file changed, 3 insertions(+), 2 deletions(-)

diff --git a/modules/demux/mpeg/ts_psi.c b/modules/demux/mpeg/ts_psi.c
index 54b58306413..b01fd098323 100644
--- a/modules/demux/mpeg/ts_psi.c
+++ b/modules/demux/mpeg/ts_psi.c
@@ -2249,9 +2249,10 @@ static void PMTCallBack( void *data, dvbpsi_pmt_t *p_dvbpsipmt )
             ProbeStart( p_demux, p_pmt->i_number );
         ProbeEnd( p_demux, p_pmt->i_number );
         p_pmt->b_last_dts_probed = true;
+        vlc_tick_t i_start = (p_pmt->pcr.i_first != VLC_TICK_INVALID) ? p_pmt->pcr.i_first : p_pmt->pcr.i_first_dts;
         if( p_pmt->i_last_dts != VLC_TICK_INVALID &&
-            p_pmt->i_last_dts < p_pmt->pcr.i_first_dts )
-            p_pmt->i_last_dts = TimeStampWrapAround( p_pmt->pcr.i_first_dts, p_pmt->i_last_dts );
+            p_pmt->i_last_dts < i_start )
+            p_pmt->i_last_dts = TimeStampWrapAround( i_start, p_pmt->i_last_dts );
     }
 
     dvbpsi_pmt_delete( p_dvbpsipmt );
