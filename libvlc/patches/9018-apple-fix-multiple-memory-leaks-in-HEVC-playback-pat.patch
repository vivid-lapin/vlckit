From 5e13bdaf3e6b4b90739bbe99970992617ba8caff Mon Sep 17 00:00:00 2001
From: ci7lus <7887955+ci7lus@users.noreply.github.com>
Date: Fri, 20 Mar 2026 17:29:15 +0900
Subject: [PATCH] apple: fix multiple memory leaks in HEVC playback path

---
 modules/codec/videotoolbox/decoder.c                | 13 +++++++++----
 modules/codec/vt_utils.c                            |  6 +++++-
 modules/video_output/apple/VLCSampleBufferDisplay.m | 12 +++++++-----
 3 files changed, 21 insertions(+), 10 deletions(-)

diff --git a/modules/codec/videotoolbox/decoder.c b/modules/codec/videotoolbox/decoder.c
index d09ada7a8a..27e8b57307 100644
--- a/modules/codec/videotoolbox/decoder.c
+++ b/modules/codec/videotoolbox/decoder.c
@@ -1306,7 +1306,8 @@ static void CloseDecoder(vlc_object_t *p_this)
     if (p_sys->pf_codec_clean)
         p_sys->pf_codec_clean(p_sys->p_codec_context);
 
-    vlc_video_context_Release(p_sys->vctx);
+    if (p_sys->vctx)
+        vlc_video_context_Release(p_sys->vctx);
 
     free(p_sys);
 }
@@ -2109,6 +2110,13 @@ static void DecoderCallback(void *decompressionOutputRefCon,
     decoder_t *p_dec = (decoder_t *)decompressionOutputRefCon;
     decoder_sys_t *p_sys = p_dec->p_sys;
     frame_info_t *p_info = (frame_info_t *) sourceFrameRefCon;
+
+    if (unlikely(p_info == NULL))
+    {
+        msg_Err(p_dec, "critical: null sourceFrameRefCon in DecoderCallback");
+        return;
+    }
+
     const bool b_field = p_info->b_field;
 
     vlc_mutex_lock(&p_sys->lock);
@@ -2159,9 +2167,6 @@ static void DecoderCallback(void *decompressionOutputRefCon,
     if (CVPixelBufferGetDataSize(imageBuffer) == 0)
         goto end;
 
-    if (unlikely(p_info == NULL))
-        goto end;
-
     /* Unlock the mutex because decoder_NewPicture() is blocking. Indeed,
          * it can wait indefinitely when the input is paused. */
 
diff --git a/modules/codec/vt_utils.c b/modules/codec/vt_utils.c
index 7012a52ee7..f598724bd7 100644
--- a/modules/codec/vt_utils.c
+++ b/modules/codec/vt_utils.c
@@ -57,14 +57,18 @@ static void
 cvpxpic_destroy_cb(picture_context_t *opaque)
 {
     struct cvpxpic_ctx *ctx = (struct cvpxpic_ctx *)opaque;
+    vlc_video_context *vctx = opaque->vctx;
 
     if (vlc_atomic_rc_dec(&ctx->rc))
     {
         CFRelease(ctx->cvpx);
         if (ctx->on_released_cb)
-            ctx->on_released_cb(opaque->vctx, ctx->nb_fields);
+            ctx->on_released_cb(vctx, ctx->nb_fields);
         free(opaque);
     }
+
+    if (vctx)
+        vlc_video_context_Release(vctx);
 }
 
 static picture_context_t *
diff --git a/modules/video_output/apple/VLCSampleBufferDisplay.m b/modules/video_output/apple/VLCSampleBufferDisplay.m
index 82b58387ce..96b9f8afce 100644
--- a/modules/video_output/apple/VLCSampleBufferDisplay.m
+++ b/modules/video_output/apple/VLCSampleBufferDisplay.m
@@ -1059,12 +1059,14 @@ static void PrepareDisplay (vout_display_t *vd) {
 static void Prepare (vout_display_t *vd, picture_t *pic,
                      const vlc_render_subpicture *subpicture, vlc_tick_t date)
 {
-    PrepareDisplay(vd);
-    if (pic) {
-        RenderPicture(vd, pic, date);
-    }
+    @autoreleasepool {
+        PrepareDisplay(vd);
+        if (pic) {
+            RenderPicture(vd, pic, date);
+        }
 
-    RenderSubpicture(vd, subpicture);
+        RenderSubpicture(vd, subpicture);
+    }
 }
 
 static void Display(vout_display_t *vd, picture_t *pic)
-- 
2.39.1

