diff --git a/modules/demux/mpeg/ts.c b/modules/demux/mpeg/ts.c
index 7b7b461f6eb..787523234b5 100644
--- a/modules/demux/mpeg/ts.c
+++ b/modules/demux/mpeg/ts.c
@@ -673,6 +673,13 @@ static int Demux( demux_t *p_demux )
 
         /* Parse the TS packet */
         ts_pid_t *p_pid = GetPID( p_sys, PIDGet( p_pkt ) );
+        if( p_pid->i_pid == 320 || p_pid->i_pid == 352 )
+        {
+             static int i_count[8192] = {0};
+             if ( i_count[p_pid->i_pid]++ % 100 == 0 )
+                 msg_Info( p_demux, "BML: Seen packet for PID %d, type=%d, filtered=%d, seen=%d", 
+                           p_pid->i_pid, p_pid->type, !!(p_pid->i_flags & FLAG_FILTERED), !!SEEN(p_pid) );
+        }
         if( !SEEN(p_pid) )
         {
             if( p_pid->type == TYPE_FREE )
@@ -739,6 +746,8 @@ static int Demux( demux_t *p_demux )
             }
             else if( p_pid->u.p_stream->transport == TS_TRANSPORT_SECTIONS )
             {
+                if ( p_pid->i_pid == 320 || p_pid->i_pid == 352 ) /* Typical BML PIDs */
+                    msg_Info( p_demux, "BML: Calling GatherSectionsData for pid %d", p_pid->i_pid );
                 b_frame = GatherSectionsData( p_demux, p_pid, p_pkt, i_header );
             }
             else // pid->u.p_pes->transport == TS_TRANSPORT_IGNORE
@@ -866,9 +875,18 @@ void UpdatePESFilters( demux_t *p_demux, bool b_all )
 
                 if( b_stream_selected )
                 {
-                    msg_Dbg( p_demux, "enabling pid %d from program %d", espid->i_pid, p_pmt->i_number );
+                    if ( p_pes->transport == TS_TRANSPORT_SECTIONS )
+                        msg_Info( p_demux, "BML: re-enabling filtered flag for pid %d (always_receive=%d)", 
+                                  espid->i_pid, p_pes->b_always_receive );
+                    else
+                        msg_Dbg( p_demux, "enabling pid %d from program %d", espid->i_pid, p_pmt->i_number );
                     espid->i_flags |= FLAG_FILTERED;
                 }
+                else if ( p_pes->transport == TS_TRANSPORT_SECTIONS )
+                {
+                     msg_Info( p_demux, "BML: PID %d NOT re-enabled (always_receive=%d)", 
+                               espid->i_pid, p_pes->b_always_receive );
+                }
             }
 
             /* Select pcr last in case it is handled by unselected ES */
@@ -2722,9 +2740,16 @@ static bool GatherPESData( demux_t *p_demux, ts_pid_t *p_pid, block_t *p_pkt, si
 
 static bool GatherSectionsData( demux_t *p_demux, ts_pid_t *p_pid, block_t *p_pkt, size_t i_skip )
 {
-    VLC_UNUSED(i_skip); VLC_UNUSED(p_demux);
+    VLC_UNUSED(i_skip);
     bool b_ret = false;
 
+    if( p_pid->u.p_stream->transport == TS_TRANSPORT_SECTIONS )
+        msg_Info( p_demux, "BML: GatherSectionsData pid=%d proc=%p scrambled=%d pusi=%d",
+                  p_pid->i_pid,
+                  (void*)p_pid->u.p_stream->p_sections_proc,
+                  !!(p_pkt->i_flags & BLOCK_FLAG_SCRAMBLED),
+                  !!(p_pkt->p_buffer[1] & 0x40) );
+
     if( p_pkt->i_flags & BLOCK_FLAG_DISCONTINUITY )
     {
         ts_sections_processor_Reset( p_pid->u.p_stream->p_sections_proc );
diff --git a/modules/demux/mpeg/ts_arib.c b/modules/demux/mpeg/ts_arib.c
index 3f4f2212625..ee14c5f5853 100644
--- a/modules/demux/mpeg/ts_arib.c
+++ b/modules/demux/mpeg/ts_arib.c
@@ -28,6 +28,7 @@
 #include "ts.h"
 
 #include "ts_arib.h"
+#include "ts_streams_private.h"
 
 /*
  * ARIB TR-B21
@@ -656,3 +657,37 @@ char * ts_arib_Decode( const uint8_t *p_in, size_t i_in )
 
     return stream.ptr;
 }
+
+void BML_Section_Callback( demux_t *p_demux,
+                           const uint8_t *p_sectiondata, size_t i_sectiondata,
+                           const uint8_t *p_payloaddata, size_t i_payloaddata,
+                           void *p_pes_cb_data )
+{
+    VLC_UNUSED(p_payloaddata); VLC_UNUSED(i_payloaddata);
+    ts_stream_t *p_pes = (ts_stream_t *) p_pes_cb_data;
+
+    if( unlikely(p_pes->p_es->fmt.i_codec != VLC_CODEC_ARIB_BML) )
+    {
+        msg_Info( p_demux, "BML: section callback: unexpected codec %4.4s, ignoring", (char*)&p_pes->p_es->fmt.i_codec );
+        return;
+    }
+
+    msg_Info( p_demux, "BML: section callback called, size %zu", i_sectiondata );
+
+    vlc_object_t *obj = VLC_OBJECT(p_demux);
+    void (*cb)(const uint8_t*, size_t, void*) = NULL;
+    void *opaque = NULL;
+
+    while (obj != NULL) {
+        if (var_Type(obj, "bml-data-cb") != 0) {
+            cb = (void(*)(const uint8_t*, size_t, void*))var_GetAddress(obj, "bml-data-cb");
+            opaque = var_GetAddress(obj, "bml-data-opaque");
+            break;
+        }
+        obj = vlc_object_parent(obj);
+    }
+
+    if (cb) {
+        cb(p_sectiondata, i_sectiondata, opaque);
+    }
+}
diff --git a/modules/demux/mpeg/ts_arib.h b/modules/demux/mpeg/ts_arib.h
index 0a859adbec4..128463255f9 100644
--- a/modules/demux/mpeg/ts_arib.h
+++ b/modules/demux/mpeg/ts_arib.h
@@ -53,4 +53,9 @@ bool ts_arib_inject_png_palette( const uint8_t *p_in, size_t i_in,
 
 char * ts_arib_Decode( const uint8_t *p_in, size_t i_in );
 
+void BML_Section_Callback( demux_t *p_demux,
+                           const uint8_t *p_sectiondata, size_t i_sectiondata,
+                           const uint8_t *p_payloaddata, size_t i_payloaddata,
+                           void *p_pes_cb_data );
+
 #endif
diff --git a/modules/demux/mpeg/ts_pid.c b/modules/demux/mpeg/ts_pid.c
index be9cfaa49fb..f4671a93236 100644
--- a/modules/demux/mpeg/ts_pid.c
+++ b/modules/demux/mpeg/ts_pid.c
@@ -260,7 +260,13 @@ void PIDRelease( demux_t *p_demux, ts_pid_t *pid )
         assert( pid->type == TYPE_FREE );
         return;
     }
-    else if( pid->i_refcount == 1 )
+    if ( pid->i_flags & FLAG_BML_STICKY )
+    {
+        msg_Info( p_demux, "BML: PIDRelease called for sticky PID %d, ignoring", pid->i_pid );
+        return;
+    }
+
+    if( pid->i_refcount == 1 )
     {
         pid->i_refcount--;
     }
diff --git a/modules/demux/mpeg/ts_pid.h b/modules/demux/mpeg/ts_pid.h
index af68c98308d..79aac47efc3 100644
--- a/modules/demux/mpeg/ts_pid.h
+++ b/modules/demux/mpeg/ts_pid.h
@@ -44,7 +44,8 @@ enum
     FLAGS_NONE = 0,
     FLAG_SEEN  = 1,
     FLAG_SCRAMBLED = 2,
-    FLAG_FILTERED = 4
+    FLAG_FILTERED = 4,
+    FLAG_BML_STICKY = 8
 };
 
 #define SEEN(x) ((x)->i_flags & FLAG_SEEN)
diff --git a/modules/demux/mpeg/ts_psi.c b/modules/demux/mpeg/ts_psi.c
index 7ef3dd87211..d1557a23a29 100644
--- a/modules/demux/mpeg/ts_psi.c
+++ b/modules/demux/mpeg/ts_psi.c
@@ -39,6 +39,7 @@
 #include "ts_streams.h"
 #include "ts_psi.h"
 #include "ts_pid.h"
+#include "ts_arib.h"
 #include "ts_streams_private.h"
 #include "ts.h"
 
@@ -1583,6 +1584,7 @@ static bool PMTSetupEsRegistration( demux_t *p_demux, ts_es_t *p_es,
 static void PIDFillFormat( demux_t *p_demux, ts_stream_t *p_pes,
                            int i_stream_type, ts_transport_type_t *p_datatype )
 {
+    demux_sys_t *p_sys = p_demux->p_sys;
     es_format_t *fmt = &p_pes->p_es->fmt;
     switch( i_stream_type )
     {
@@ -1590,6 +1592,20 @@ static void PIDFillFormat( demux_t *p_demux, ts_stream_t *p_pes,
         es_format_Change( fmt, VIDEO_ES, VLC_CODEC_MPGV );
         fmt->i_original_fourcc = VLC_CODEC_MP1V;
         break;
+    case 0x0D: /* DSM-CC sections (ARIB BML) */
+        msg_Info( p_demux, "BML: found stream type 0x0D, standard is %d", p_sys->standard );
+        if( p_sys->standard == TS_STANDARD_ARIB )
+        {
+            msg_Info( p_demux, "BML: identifying DSM-CC stream (0x0D)" );
+            /* Use UNKNOWN_ES so no decoder is started; data is delivered entirely
+             * through the sections processor callback (BML_Section_Callback). */
+            es_format_Change( fmt, UNKNOWN_ES, VLC_CODEC_ARIB_BML );
+            *p_datatype = TS_TRANSPORT_SECTIONS;
+            ts_sections_processor_Add( p_demux, &p_pes->p_sections_proc, 0, 0,
+                                       BML_Section_Callback, p_pes );
+            p_pes->b_always_receive = true;
+        }
+        break;
     case 0x02:  /* MPEG-2 video */
     case 0x80:  /* MPEG-2 MOTO video */
         es_format_Change( fmt, VIDEO_ES, VLC_CODEC_MPGV );
@@ -1691,6 +1707,26 @@ static void FillPESFromDvbpsiES( demux_t *p_demux,
 
     p_pes->i_stream_type = p_dvbpsies->i_type;
 
+    if ( p_pes->p_es->fmt.i_codec == VLC_CODEC_ARIB_BML )
+    {
+        ts_pid_t *pespid = GetPID(p_sys, p_dvbpsies->i_pid);
+        pespid->i_flags |= FLAG_BML_STICKY;
+        /* Ensure transport and sections callback are set on the actual active stream */
+        ts_stream_t *p_active = pespid->u.p_stream;
+        msg_Info( p_demux, "BML: FillPES pid %d sections_proc=%p transport_before=%d",
+                  p_dvbpsies->i_pid, (void*)p_active->p_sections_proc, (int)p_active->transport );
+        p_active->transport = TS_TRANSPORT_SECTIONS;
+        p_active->b_always_receive = true;
+        ts_sections_processor_Add( p_demux, &p_active->p_sections_proc, 0, 0,
+                                   BML_Section_Callback, p_active );
+        /* Force FLAG_FILTERED so packets are always delivered regardless of
+         * access-control or ES selection state. BML has no VLC decoder. */
+        SetPIDFilter( p_sys, pespid, true );
+        msg_Info( p_demux, "BML: FillPES pid %d done, transport=%d filtered=%d",
+                  p_dvbpsies->i_pid, (int)p_active->transport,
+                  !!(pespid->i_flags & FLAG_FILTERED) );
+    }
+
     bool b_registration_applied = false;
     if ( p_dvbpsies->i_type >= 0x80 ) /* non standard, extensions */
     {
@@ -1729,7 +1765,8 @@ static void FillPESFromDvbpsiES( demux_t *p_demux,
         case 0x0b:
         case 0x0c:
         case 0x0d:
-            p_pes->transport = TS_TRANSPORT_IGNORE;
+            if( p_sys->standard != TS_STANDARD_ARIB )
+                p_pes->transport = TS_TRANSPORT_IGNORE;
             break;
         /* All other private or reserved types */
         case 0x13: /* SL in sections */
