     B(VLC_CODEC_ARIB_C, "ARIB subtitles (C-profile)"),
         A("arbc"),
 
+    B(VLC_CODEC_ARIB_BML, "ARIB BML (Data Broadcasting)"),
+        A("arbm"),
+
     B(VLC_CODEC_BD_PG, "BD PGS subtitles"),
         A("bdpg"),
 
