From 5c9ee74042c33455bbaee2c8fd7bc1b7ca409457 Mon Sep 17 00:00:00 2001
From: ci7lus <7887955+ci7lus@users.noreply.github.com>
Date: Sun, 26 Apr 2026 15:29:10 +0900
Subject: [PATCH] demux/mpeg: Fix stream duration when PCR pid changes across
 PMT updates

Some ARIB broadcasts change the PCR pid in a later PMT version. This
causes stream duration to be unavailable in two ways:

1. ProbeEnd runs with the initial PCR pid and finds nothing at the end
   of the file, leaving i_last_dts as VLC_TICK_INVALID. The
   b_last_dts_probed flag then blocks any retry on the next PMT update.

2. ProbeEnd succeeds with the old PCR pid but returns an i_last_dts
   that is earlier than i_first (measured by the new PCR pid after
   program switch), causing DEMUX_GET_LENGTH to report "Can't get
   stream duration. Edited ?"

Fix both cases by tracking the previous PCR pid across PMT updates.
When a PCR pid change is detected, reset i_last_dts and re-run
ProbeEnd with the new pid. ProbeStart is skipped as pcr.i_first
remains valid from the initial probe.
---
 modules/demux/mpeg/ts_psi.c | 12 +++++++++---
 1 file changed, 9 insertions(+), 3 deletions(-)

diff --git a/modules/demux/mpeg/ts_psi.c b/modules/demux/mpeg/ts_psi.c
index 7ef3dd87211..0ca173d1b4a 100644
--- a/modules/demux/mpeg/ts_psi.c
+++ b/modules/demux/mpeg/ts_psi.c
@@ -1920,6 +1920,7 @@ static void PMTCallBack( void *data, dvbpsi_pmt_t *p_dvbpsipmt )
 
     msg_Dbg( p_demux, "new PMT program number=%d version=%d pid_pcr=%d",
              p_dvbpsipmt->i_program_number, p_dvbpsipmt->i_version, p_dvbpsipmt->i_pcr_pid );
+    uint16_t i_old_pid_pcr = p_pmt->i_pid_pcr;
     p_pmt->i_pid_pcr = p_dvbpsipmt->i_pcr_pid;
     p_pmt->i_version = p_dvbpsipmt->i_version;
 
@@ -2242,9 +2243,14 @@ static void PMTCallBack( void *data, dvbpsi_pmt_t *p_dvbpsipmt )
     UpdatePESFilters( p_demux, p_sys->seltype == PROGRAM_ALL );
 
     /* Probe Boundaries */
-    if( p_sys->b_canseek && !p_pmt->b_last_dts_probed )
-    {
-        ProbeStart( p_demux, p_pmt->i_number );
+    bool b_pcr_pid_changed = p_pmt->b_last_dts_probed && i_old_pid_pcr != p_pmt->i_pid_pcr;
+    if( p_sys->b_canseek &&
+        (!p_pmt->b_last_dts_probed || b_pcr_pid_changed || p_pmt->i_last_dts == VLC_TICK_INVALID) )
+    {
+        if( !p_pmt->b_last_dts_probed )
+            ProbeStart( p_demux, p_pmt->i_number );
+        if( b_pcr_pid_changed )
+            p_pmt->i_last_dts = VLC_TICK_INVALID;
         ProbeEnd( p_demux, p_pmt->i_number );
         p_pmt->b_last_dts_probed = true;
         if( p_pmt->i_last_dts != VLC_TICK_INVALID &&
-- 
