From cfe6aa71fc46f2d3c4af60fcaf3cafb27e6a3287 Mon Sep 17 00:00:00 2001
From: ci7lus <7887955+ci7lus@users.noreply.github.com>
Date: Thu, 9 Apr 2026 22:30:29 +0900
Subject: [PATCH] feat: Add callback for libaribcaption

---
 include/vlc/libvlc_media_player.h   | 22 ++++++++++++++++++++++
 lib/libvlc.sym                      |  1 +
 lib/media_player.c                  | 17 +++++++++++++++++
 lib/media_player_internal.h         |  3 +++
 modules/codec/arib/libaribcaption.c | 20 ++++++++++++++++++++
 5 files changed, 63 insertions(+)

diff --git a/include/vlc/libvlc_media_player.h b/include/vlc/libvlc_media_player.h
index 7e28aeda59..44ec13feb7 100644
--- a/include/vlc/libvlc_media_player.h
+++ b/include/vlc/libvlc_media_player.h
@@ -412,6 +412,15 @@ typedef void (*libvlc_video_unlock_cb)(void *opaque, void *picture,
  */
 typedef void (*libvlc_video_display_cb)(void *opaque, void *picture);
 
+/**
+ * Callback prototype to report ARIB caption text.
+ *
+ * \param text decoded string
+ * \param pts presentation time stamp in milliseconds
+ * \param opaque user data
+ */
+typedef void (*libvlc_video_arib_text_cb)(const char *text, int64_t pts, void *opaque);
+
 /**
  * Callback prototype to configure picture buffers format.
  * This callback gets the format of the video as output by the video decoder
@@ -500,6 +509,19 @@ void libvlc_video_set_callbacks( libvlc_media_player_t *mp,
                                  libvlc_video_display_cb display,
                                  void *opaque );
 
+/**
+ * Set callbacks to receive decoded ARIB caption text.
+ *
+ * \param mp the media player
+ * \param cb callback to report text (or NULL)
+ * \param opaque private pointer for the callback
+ */
+LIBVLC_API
+void libvlc_video_set_arib_text_callbacks( libvlc_media_player_t *mp,
+                                           libvlc_video_arib_text_cb cb,
+                                           void *opaque );
+
+
 /**
  * Set decoded video chroma and dimensions.
  * This only works in combination with libvlc_video_set_callbacks(),
diff --git a/lib/libvlc.sym b/lib/libvlc.sym
index 5fd0216314..df1b6adfff 100644
--- a/lib/libvlc.sym
+++ b/lib/libvlc.sym
@@ -260,6 +260,7 @@ libvlc_video_set_adjust_float
 libvlc_video_set_adjust_int
 libvlc_video_set_aspect_ratio
 libvlc_video_set_callbacks
+libvlc_video_set_arib_text_callbacks
 libvlc_video_set_crop_ratio
 libvlc_video_set_crop_window
 libvlc_video_set_crop_border
diff --git a/lib/media_player.c b/lib/media_player.c
index a3c62b9381..95f4983688 100644
--- a/lib/media_player.c
+++ b/lib/media_player.c
@@ -1093,6 +1093,23 @@ void libvlc_video_set_callbacks( libvlc_media_player_t *mp,
     var_SetString( mp, "window", "dummy" );
 }
 
+
+
+void libvlc_video_set_arib_text_callbacks( libvlc_media_player_t *mp,
+                                           libvlc_video_arib_text_cb cb,
+                                           void *opaque )
+{
+    libvlc_instance_t *p_libvlc = mp->p_libvlc_instance;
+
+    if (var_Type(p_libvlc->p_libvlc_int, "arib-text-cb") == 0)
+        var_Create(p_libvlc->p_libvlc_int, "arib-text-cb", VLC_VAR_ADDRESS);
+    var_SetAddress(p_libvlc->p_libvlc_int, "arib-text-cb", (void*)cb);
+
+    if (var_Type(p_libvlc->p_libvlc_int, "arib-text-opaque") == 0)
+        var_Create(p_libvlc->p_libvlc_int, "arib-text-opaque", VLC_VAR_ADDRESS);
+    var_SetAddress(p_libvlc->p_libvlc_int, "arib-text-opaque", opaque);
+}
+
 void libvlc_video_set_format_callbacks( libvlc_media_player_t *mp,
                                         libvlc_video_format_cb setup,
                                         libvlc_video_cleanup_cb cleanup )
diff --git a/lib/media_player_internal.h b/lib/media_player_internal.h
index 885b001ccc..d093999ed8 100644
--- a/lib/media_player_internal.h
+++ b/lib/media_player_internal.h
@@ -43,6 +43,9 @@ struct libvlc_media_player_t
     vlc_player_aout_listener_id *aout_listener;
     vlc_cond_t wait;
 
+    libvlc_video_arib_text_cb arib_text_cb;
+    void *arib_text_opaque;
+
     struct libvlc_instance_t * p_libvlc_instance; /* Parent instance */
     libvlc_media_t * p_md; /* current media descriptor */
     libvlc_event_manager_t event_manager;
diff --git a/modules/codec/arib/libaribcaption.c b/modules/codec/arib/libaribcaption.c
index 774a225e1a..f94571dd59 100644
--- a/modules/codec/arib/libaribcaption.c
+++ b/modules/codec/arib/libaribcaption.c
@@ -256,6 +256,26 @@ static int Decode(decoder_t *p_dec, block_t *p_block)
     vlc_mutex_lock(&p_sys->aribcc_lock);
     aribcc_renderer_append_caption(p_sys->p_renderer, &caption);
     vlc_mutex_unlock(&p_sys->aribcc_lock);
+
+    if (caption.text && *caption.text) {
+        vlc_object_t *obj = VLC_OBJECT(p_dec);
+        void (*cb)(const char*, int64_t, void*) = NULL;
+        void *opaque = NULL;
+
+        while (obj != NULL) {
+            if (var_Type(obj, "arib-text-cb") != 0) {
+                cb = (void(*)(const char*, int64_t, void*))var_GetAddress(obj, "arib-text-cb");
+                opaque = var_GetAddress(obj, "arib-text-opaque");
+                break;
+            }
+            obj = vlc_object_parent(obj);
+        }
+
+        if (cb) {
+            cb(caption.text, (int64_t)MS_FROM_VLC_TICK(p_block->i_pts), opaque);
+        }
+    }
+
     aribcc_caption_cleanup(&caption);
 
 
-- 
2.39.1

