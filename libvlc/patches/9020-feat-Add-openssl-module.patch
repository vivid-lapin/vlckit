Date: Tue, 24 Mar 2026 21:42:01 +0900
Subject: [PATCH] feat: Add openssl module

---
 configure.ac                    |  12 ++
 contrib/src/openssl/SHA512SUMS  |   1 +
 contrib/src/openssl/rules.mak   |  68 ++++++++
 extras/package/apple/build.conf |   3 +
 modules/misc/Makefile.am        |   7 +
 modules/misc/openssl.c          | 301 ++++++++++++++++++++++++++++++++
 6 files changed, 392 insertions(+)
 create mode 100644 contrib/src/openssl/SHA512SUMS
 create mode 100644 contrib/src/openssl/rules.mak
 create mode 100644 modules/misc/openssl.c

diff --git a/configure.ac b/configure.ac
index ea348ce184..79713c3238 100644
--- a/configure.ac
+++ b/configure.ac
@@ -4776,6 +4776,18 @@ AM_CONDITIONAL([HAVE_GCRYPT], [test "${ac_cv_lib_gcrypt}" = "yes"])
 dnl
 dnl TLS/SSL
 dnl
+AC_ARG_ENABLE([openssl],
+  AS_HELP_STRING([--enable-openssl], [OpenSSL TLS/SSL support (default enabled)]))
+AS_IF([test "${enable_openssl}" != "no"], [
+  PKG_CHECK_MODULES(OPENSSL, [openssl >= 1.1.0], [
+    VLC_ADD_PLUGIN([openssl])
+  ], [
+    AS_IF([test -n "${enable_openssl}"], [
+      AC_MSG_ERROR([${OPENSSL_PKG_ERRORS}.])
+    ])
+  ])
+])
+
 AC_ARG_ENABLE([gnutls],
   AS_HELP_STRING([--enable-gnutls], [GNU TLS TLS/SSL support (default enabled)]))
 AS_IF([test "${enable_gnutls}" != "no"], [
