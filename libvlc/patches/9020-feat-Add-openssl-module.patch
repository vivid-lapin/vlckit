+ * along with this program; if not, write to the Free Software Foundation,
+ * Inc., 51 Franklin Street, Fifth Floor, Boston MA 02110-1301, USA.
+ *****************************************************************************/
+
+#ifdef HAVE_CONFIG_H
+# include "config.h"
+#endif
+
+#include <vlc_common.h>
+#include <vlc_plugin.h>
+#include <vlc_tls.h>
+#include <vlc_fs.h>
+
+#include <openssl/ssl.h>
+#include <openssl/err.h>
+#include <openssl/x509v3.h>
+
+typedef struct vlc_tls_openssl {
+    vlc_tls_t tls;
+    SSL *ssl;
+    vlc_object_t *obj;
+} vlc_tls_openssl_t;
+
+static int openssl_Error(vlc_object_t *obj, const char *msg, int ret) {
+    unsigned long err = ERR_get_error();
+    if (err) {
+        char errbuf[256];
+        ERR_error_string_n(err, errbuf, sizeof(errbuf));
+        msg_Err(obj, "%s: %s (ret=%d)", msg, errbuf, ret);
+    } else {
+        msg_Err(obj, "%s (ret=%d)", msg, ret);
+    }
+    return -1;
+}
+
+/* Custom BIO for VLC transport */
+static int vlc_bio_write(BIO *b, const char *buf, int len) {
+    vlc_tls_t *sock = BIO_get_data(b);
+    BIO_clear_retry_flags(b);
+    ssize_t ret = vlc_tls_Write(sock, buf, len);
+    if (ret < 0) {
+        if (errno == EAGAIN || errno == EINTR)
+            BIO_set_retry_write(b);
+    }
+    return ret;
+}
+
+static int vlc_bio_read(BIO *b, char *buf, int len) {
+    vlc_tls_t *sock = BIO_get_data(b);
+    BIO_clear_retry_flags(b);
+    ssize_t ret = vlc_tls_Read(sock, buf, len, false);
+    if (ret < 0) {
+        if (errno == EAGAIN || errno == EINTR)
+            BIO_set_retry_read(b);
+    }
+    return ret;
+}
+
+static long vlc_bio_ctrl(BIO *b, int cmd, long num, void *ptr) {
+    (void)num; (void)ptr;
+    switch (cmd) {
+        case BIO_CTRL_FLUSH: return 1;
+        default: return 0;
+    }
+}
+
+static int vlc_bio_create(BIO *b) {
+    BIO_set_init(b, 1);
+    BIO_set_data(b, NULL);
+    BIO_set_shutdown(b, 0);
+    return 1;
+}
+
+static int vlc_bio_destroy(BIO *b) {
+    if (b == NULL) return 0;
+    return 1;
+}
+
+static BIO_METHOD *vlc_bio_method = NULL;
+
+static int openssl_GetFD(vlc_tls_t *tls, short *restrict events) {
+    vlc_tls_openssl_t *priv = (vlc_tls_openssl_t *)tls;
+    BIO *b = SSL_get_rbio(priv->ssl);
+    vlc_tls_t *sock = BIO_get_data(b);
+    return vlc_tls_GetPollFD(sock, events);
+}
+
+static ssize_t openssl_Recv(vlc_tls_t *tls, struct iovec *iov, unsigned count) {
+    vlc_tls_openssl_t *priv = (vlc_tls_openssl_t *)tls;
+    size_t rcvd = 0;
+
+    for (unsigned i = 0; i < count; i++) {
+        int ret = SSL_read(priv->ssl, iov[i].iov_base, iov[i].iov_len);
+        if (ret <= 0) {
+            int err = SSL_get_error(priv->ssl, ret);
+            if (rcvd > 0 || err == SSL_ERROR_WANT_READ || err == SSL_ERROR_WANT_WRITE)
+                break;
+            return -1;
+        }
+        rcvd += ret;
+        if ((size_t)ret < iov[i].iov_len)
+            break;
+    }
+    return rcvd;
+}
+
+static ssize_t openssl_Send(vlc_tls_t *tls, const struct iovec *iov, unsigned count) {
+    vlc_tls_openssl_t *priv = (vlc_tls_openssl_t *)tls;
+    size_t sent = 0;
+
+    for (unsigned i = 0; i < count; i++) {
+        int ret = SSL_write(priv->ssl, iov[i].iov_base, iov[i].iov_len);
+        if (ret <= 0) {
+            int err = SSL_get_error(priv->ssl, ret);
+            if (sent > 0 || err == SSL_ERROR_WANT_READ || err == SSL_ERROR_WANT_WRITE)
+                break;
+            return -1;
+        }
+        sent += ret;
+        if ((size_t)ret < iov[i].iov_len)
+            break;
+    }
+    return sent;
+}
+
+static int openssl_Shutdown(vlc_tls_t *tls, bool duplex) {
+    vlc_tls_openssl_t *priv = (vlc_tls_openssl_t *)tls;
+    (void)duplex;
+    int ret = SSL_shutdown(priv->ssl);
+    if (ret < 0)
+        return openssl_Error(priv->obj, "SSL shutdown failed", ret);
+    return 0;
+}
+
+static void openssl_Close(vlc_tls_t *tls) {
+    vlc_tls_openssl_t *priv = (vlc_tls_openssl_t *)tls;
+    SSL_free(priv->ssl);
+    free(priv);
+}
+
+static const struct vlc_tls_operations openssl_ops = {
+    openssl_GetFD, openssl_Recv, openssl_Send, openssl_Shutdown, openssl_Close,
+};
+
+static int openssl_Handshake(vlc_tls_t *tls, char **restrict alp) {
+    vlc_tls_openssl_t *priv = (vlc_tls_openssl_t *)tls;
+    int ret = SSL_do_handshake(priv->ssl);
+    if (ret == 1) {
+        if (alp) {
+            const unsigned char *proto;
+            unsigned int len;
+            SSL_get0_alpn_selected(priv->ssl, &proto, &len);
+            if (len > 0)
+                *alp = strndup((const char *)proto, len);
+            else
+                *alp = NULL;
+        }
+        return 0;
+    }
+
+    int err = SSL_get_error(priv->ssl, ret);
+    if (err == SSL_ERROR_WANT_READ) return 1;
+    if (err == SSL_ERROR_WANT_WRITE) return 2;
+
+    openssl_Error(priv->obj, "Handshake failed", ret);
+    return -1;
+}
+
+static int openssl_ClientHandshake(vlc_tls_t *tls, const char *host,
+                                   const char *service, char **restrict alp) {
+    (void)host; (void)service;
+    return openssl_Handshake(tls, alp);
+}
+
+static vlc_tls_t *openssl_ClientSessionOpen(vlc_tls_client_t *crd, vlc_tls_t *sock,
+                                           const char *hostname, const char *const *alpn) {
+    vlc_tls_openssl_t *priv = malloc(sizeof(*priv));
+    if (unlikely(priv == NULL)) return NULL;
+
+    priv->obj = VLC_OBJECT(crd);
+    priv->ssl = SSL_new(crd->sys);
+    if (priv->ssl == NULL) {
+        free(priv);
+        return NULL;
+    }
+
+    BIO *b = BIO_new(vlc_bio_method);
+    if (b == NULL) {
+        SSL_free(priv->ssl);
+        free(priv);
+        return NULL;
+    }
+    BIO_set_data(b, sock);
+    SSL_set_bio(priv->ssl, b, b);
+
+    if (hostname) {
+        SSL_set_tlsext_host_name(priv->ssl, hostname);
+        X509_VERIFY_PARAM *param = SSL_get0_param(priv->ssl);
+        X509_VERIFY_PARAM_set1_host(param, hostname, 0);
+    }
+
+    if (alpn && *alpn) {
+        unsigned char protocols[256];
+        unsigned int len = 0;
+        for (int i = 0; alpn[i]; i++) {
+            size_t n = strlen(alpn[i]);
+            if (len + n + 1 > sizeof(protocols)) break;
+            protocols[len++] = n;
+            memcpy(protocols + len, alpn[i], n);
+            len += n;
+        }
+        SSL_set_alpn_protos(priv->ssl, protocols, len);
+    }
+
+    SSL_set_connect_state(priv->ssl);
+    priv->tls.ops = &openssl_ops;
+    return &priv->tls;
+}
+
+static void openssl_ClientDestroy(vlc_tls_client_t *crd) {
+    SSL_CTX_free(crd->sys);
+}
+
+static const struct vlc_tls_client_operations openssl_client_ops = {
+    openssl_ClientSessionOpen, openssl_ClientHandshake, openssl_ClientDestroy,
+};
+
+static int OpenClient(vlc_tls_client_t *crd) {
+    if (vlc_bio_method == NULL) {
+        vlc_bio_method = BIO_meth_new(BIO_TYPE_SOURCE_SINK, "vlc_tls");
+        BIO_meth_set_write(vlc_bio_method, vlc_bio_write);
+        BIO_meth_set_read(vlc_bio_method, vlc_bio_read);
+        BIO_meth_set_ctrl(vlc_bio_method, vlc_bio_ctrl);
+        BIO_meth_set_create(vlc_bio_method, vlc_bio_create);
+        BIO_meth_set_destroy(vlc_bio_method, vlc_bio_destroy);
+    }
+
+    SSL_CTX *ctx = SSL_CTX_new(TLS_client_method());
+    if (ctx == NULL) return VLC_EGENERIC;
+
+    /* Load trust anchors */
+    char *cafile = var_InheritString(crd, "openssl-cafile");
+    char *capath = var_InheritString(crd, "openssl-capath");
+
+    if (cafile || capath) {
+        if (!SSL_CTX_load_verify_locations(ctx, cafile, capath)) {
+            msg_Err(crd, "Failed to load verify locations (file: %s, path: %s)",
+                    cafile ? cafile : "default", capath ? capath : "default");
+        }
+    } else {
+        SSL_CTX_set_default_verify_paths(ctx);
+    }
+    free(cafile);
+    free(capath);
+
+    /* Allow ignoring verification for debugging if specified */
+    if (!var_InheritBool(crd, "openssl-no-verify")) {
+        SSL_CTX_set_verify(ctx, SSL_VERIFY_PEER, NULL);
+    } else {
+        msg_Warn(crd, "SSL verification disabled by configuration!");
+        SSL_CTX_set_verify(ctx, SSL_VERIFY_NONE, NULL);
+    }
+
+    crd->ops = &openssl_client_ops;
+    crd->sys = ctx;
+    return VLC_SUCCESS;
+}
+
+#define CAFILE_TEXT N_("Root CA file")
+#define CAFILE_LONGTEXT N_("Path to a file containing trusted root certificates in PEM format.")
+#define CAPATH_TEXT N_("Root CA directory")
+#define CAPATH_LONGTEXT N_("Path to a directory containing trusted root certificates.")
+#define NO_VERIFY_TEXT N_("Disable certificate verification")
+#define NO_VERIFY_LONGTEXT N_("Do not verify the server certificate. DANGEROUS: allows man-in-the-middle attacks.")
+
+vlc_module_begin()
+    set_shortname("OpenSSL")
+    set_description(N_("OpenSSL transport layer security"))
+    set_capability("tls client", 3)
+    set_callback(OpenClient)
+    set_subcategory(SUBCAT_ADVANCED_NETWORK)
+    add_loadfile("openssl-cafile", NULL, CAFILE_TEXT, CAFILE_LONGTEXT)
+    add_directory("openssl-capath", NULL, CAPATH_TEXT, CAPATH_LONGTEXT)
+    add_bool("openssl-no-verify", false, NO_VERIFY_TEXT, NO_VERIFY_LONGTEXT)
+vlc_module_end()
-- 
