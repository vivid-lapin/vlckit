diff --git a/modules/misc/openssl.c b/modules/misc/openssl.c
new file mode 100644
index 0000000000..0fb8913ed7
--- /dev/null
+++ b/modules/misc/openssl.c
@@ -0,0 +1,301 @@
+/*****************************************************************************
+ * openssl.c
+ *****************************************************************************
+ * Copyright (C) 2024 VLC authors and VideoLAN
+ *
